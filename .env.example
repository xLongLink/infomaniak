# Infomaniak API Token (required)
# Create one at: https://manager.infomaniak.com/v3/infomaniak-api
# Required scopes: domain:read, dns:read, dns:write
INFOMANIAK_API_TOKEN=

# Account ID (optional — auto-detected if not set)
# Find yours in the manager URL: https://manager.infomaniak.com/v3/ACCOUNT_ID/...
INFOMANIAK_ACCOUNT_ID=
